    m_PersistentCalls:
      m_Calls: []
  m_text: "Hand position: Two hands centered on the chest\r\nBody position: Shoulders
    directly over hands; elbows locked\r\nCompression depth: At least 2 inches\r\nRate
    of compressions: 100 to 120 per minute\r\nAllow chest to return to normal position
    after each compression\n\r\n6. Give 2 breaths\r\n\r\nOpen the airway to a past-neutral
    position using the head-tilt/chin-lift technique\r\nPinch the nose shut, take
    a normal breath, and make complete seal over the person\u2019s mouth with your
    mouth.\r\nEnsure each breath lasts about 1 second and makes the chest rise; allow
    air to exit before giving the next breath\r\n\n7. Continue giving sets of 30
    chest compressions and 2 breaths. Use an AED as soon as one is available!"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 52665ffe99290284aba4abe6a781651f, type: 2}
  m_sharedMaterial: {fileID: -1211984561930024552, guid: 52665ffe99290284aba4abe6a781651f, type: 2}

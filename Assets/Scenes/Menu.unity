  m_OnCullStateChanged:
    m_PersistentCalls:
      m_Calls: []
  m_text: "How to give CPR in real life:\n\n1. CHECK the scene for safety.\r\n\r\n2.
    CHECK if patient is responsive.\r\n\r\n3. If the person does not respond and
    is not breathing or only gasping, CALL 9-1-1 and get equipment, or tell someone
    to do so\r\n\r\n4. Kneel beside the person. Place the person on their back on
    a firm, flat surface\r\n\r\n5. CPR guidelines recommend 100 to 120 chest compressions
    per minute, 30 at a time.\r\n\r"
  m_isRightToLeft: 0
  m_fontAsset: {fileID: 11400000, guid: 52665ffe99290284aba4abe6a781651f, type: 2}
